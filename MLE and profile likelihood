     pos = 3, col = "darkgreen", cex = 0.85)

abline(h = threshold,     col = "red",  lty = 2, lwd = 1.5)
abline(v = ci_vals$lower, col = "blue", lty = 2)
abline(v = ci_vals$upper, col = "blue", lty = 2)

text(par("usr")[1], threshold,
     labels = "95% cutoff", col = "red", adj = c(0, -0.4), cex = 0.8)
text(ci_vals$lower, par("usr")[4],
     sprintf("%.3f", ci_vals$lower), col = "blue", adj = c(0, 1), cex = 0.8)
text(ci_vals$upper, par("usr")[4],
     sprintf("%.3f", ci_vals$upper), col = "blue", adj = c(1, 1), cex = 0.8)

if (nrow(non_conv) > 0) {
  points(non_conv$f_int, rep(par("usr")[4], nrow(non_conv)),
         pch = 4, col = "orange", cex = 1.2)
  warning(sprintf("%d grid point(s) did not converge.", nrow(non_conv)))
}
