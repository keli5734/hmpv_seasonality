# 3. Load MLE results
# ─────────────────────────────────────────────
parms_mle <- readRDS(paste0("parm_",  region, "_viral_interference.rds"))
fitLL     <- readRDS(paste0("fitLL_", region, "_viral_interference.rds"))
mle_nll   <- fitLL$value
mle_f_int <- -plogis(fitLL$par["f"])
cat("MLE f_int:", mle_f_int, " | MLE -loglik:", mle_nll, "\n")

# ─────────────────────────────────────────────
# 4. Profile likelihood wrapper
# ─────────────────────────────────────────────
fit_hosp_data_fn_profile <- function(par, dat, f_int_fixed) {
  f_pinned <- qlogis(-f_int_fixed)
  full_par <- c(trans     = unname(par[1]),
                amplitude = unname(par[2]),
                transmiss = unname(par[3]),
                f         = f_pinned)
  fit_hosp_data_fn(parameters = full_par, dat = dat)
}

# ─────────────────────────────────────────────
# 5. Build grid (wide sweep + dense near MLE)
# ─────────────────────────────────────────────
f_int_grid <- sort(unique(c(
  # Extended lower tail dynamically connecting to the dense band
  seq(-0.50, mle_f_int - 0.08, length.out = 20),
  
  # Dense band around MLE
  seq(mle_f_int - 0.16, mle_f_int + 0.16, length.out = 25),
  
  # Extended upper tail to prevent right boundary censoring
  seq(mle_f_int + 0.16, -0.001, length.out = 20)
)))

# Ensure we don't accidentally exceed the absolute boundaries 
# (in case mle_f_int is very close to -0.50 or -0.001)
#f_int_grid <- f_int_grid[f_int_grid >= -0.50 & f_int_grid <= -0.001]

cat("Grid points:", length(f_int_grid), "\n")

# ─────────────────────────────────────────────
# 6. Build a set of starting values for multi-start
#    Each grid point will be attempted from all of these.
#    Using MLE params as anchor + small perturbations.
# ─────────────────────────────────────────────
mle_start <- c(
  trans     = unname(fitLL$par["trans"]),
  amplitude = unname(fitLL$par["amplitude"]),
  transmiss = unname(fitLL$par["transmiss"])
)

set.seed(42)
n_extra_starts <- 4   # additional random starts per grid point

extra_starts <- replicate(n_extra_starts, {
  mle_start + rnorm(3, mean = 0, sd = c(0.3, 0.3, 0.15))
}, simplify = FALSE)

# Clamp transmiss within [log(2.8), log(5)] for each extra start
extra_starts <- lapply(extra_starts, function(s) {
  s["transmiss"] <- pmax(log(2.8), pmin(log(5), s["transmiss"]))
  s
})

all_starts <- c(list(mle_start), extra_starts)
cat(sprintf("Multi-start: %d starts per grid point\n", length(all_starts)))

# ─────────────────────────────────────────────
# 7. Inner optimizer: try L-BFGS-B, fall back to Nelder-Mead
# ─────────────────────────────────────────────
run_one_start <- function(start, dat, fval) {
  
  # ── Attempt 1: L-BFGS-B (tighter tolerances than before) ──
  fit <- tryCatch(
    optim(
      par         = start,
      fn          = fit_hosp_data_fn_profile,
      dat         = dat,
      f_int_fixed = fval,
      method      = "L-BFGS-B",
      lower       = c(trans = -Inf, amplitude = -Inf, transmiss = log(2.8)),
      upper       = c(trans =  Inf, amplitude =  Inf, transmiss = log(5)),
      control     = list(
        trace = FALSE,
        maxit = 2000,
        factr = 1e7,    # tighter than 1e10; try 1e6 if still struggling
        pgtol = 1e-4
      )
    ),
    error = function(e) list(value = Inf, convergence = 99L, msg = e$message)
  )
  
  # ── Attempt 2: Nelder-Mead fallback if L-BFGS-B failed/diverged ──
  if (fit$convergence != 0L || !is.finite(fit$value)) {
    fit_nm <- tryCatch(
      optim(
        par         = start,
        fn          = fit_hosp_data_fn_profile,
        dat         = dat,
        f_int_fixed = fval,
        method      = "Nelder-Mead",
        control     = list(
          trace   = FALSE,
          maxit   = 5000,
          reltol  = 1e-8,
          abstol  = 1e-8
        )
      ),
      error = function(e) list(value = Inf, convergence = 99L, msg = e$message)
    )
    # Keep whichever is better
    if (is.finite(fit_nm$value) && fit_nm$value < fit$value) {
      fit <- fit_nm
    }
  }
  
  fit
}

# ─────────────────────────────────────────────
# 8. Parallel profile loop (multi-start per grid point)
# ─────────────────────────────────────────────
n_cores <- as.integer(Sys.getenv("SLURM_CPUS_PER_TASK", unset = "1"))
cat(sprintf("Using %d cores\n", n_cores))

progress_dir <- paste0("profile_progress_region", region)
dir.create(progress_dir, showWarnings = FALSE)
file.remove(list.files(progress_dir, full.names = TRUE))
cat(sprintf("Monitor with: watch -n 30 \"ls %s/ | wc -l\"  (of %d)\n",
            progress_dir, length(f_int_grid)))

cl <- makeCluster(n_cores)
registerDoParallel(cl)

clusterEvalQ(cl, {
  library(deSolve)
  library(dplyr)
})

clusterExport(cl, varlist = c(
  "fit_hosp_data_fn",
  "fit_hosp_data_fn_profile",
  "run_one_start",
  "hmpv_transmission_model_viral_interference",
  "parm_for_fit",
  "my_data",
  "all_starts",
  "yinit.vector", "yinit.matrix",
  "my_times", "t_burn_in", "N_ages", "B_part2",
  "rho1", "rho2", "sigma1", "sigma2", "sigma3",
  "region",
  "progress_dir"
))

profile_results <- foreach(
  fval     = f_int_grid,
  .combine = rbind,
  .packages = c("deSolve", "dplyr")
) %dopar% {
  
  t_start <- proc.time()["elapsed"]
  
  # ── Run all starts, keep the best ──────────
  best <- list(value = Inf, convergence = 99L, msg = "no starts run")
  
  for (s in all_starts) {
    fit_i <- run_one_start(start = s, dat = my_data, fval = fval)
    
    if (is.finite(fit_i$value) && fit_i$value < best$value) {
      best <- fit_i
    }
    
    # Early-exit: if we found a good converged solution, stop trying more starts
    if (best$convergence == 0L && is.finite(best$value)) break
  }
  # ───────────────────────────────────────────
  
  t_elapsed <- round(proc.time()["elapsed"] - t_start, 1)
  
  writeLines(
    c(sprintf("f_int  : %.6f", fval),
      sprintf("nll    : %.4f", best$value),
      sprintf("conv   : %d",   best$convergence),
      sprintf("time_s : %.1f", t_elapsed)),
    file.path(progress_dir, paste0("done_", make.names(fval), ".txt"))
  )
  
  data.frame(
    f_int     = fval,
    nll       = if (is.finite(best$value)) best$value else NA_real_,
    converged = (best$convergence == 0L),
    time_s    = t_elapsed,
    msg       = if (!is.null(best$msg)) best$msg else ""
  )
}

stopCluster(cl)
saveRDS(profile_results, paste0("profile_fint_region", region, ".rds"))
cat("\nProfile loop complete. Results saved.\n")

# ─────────────────────────────────────────────
# 9. Diagnostics + CI
# ─────────────────────────────────────────────
cat("\n--- Profile results summary ---\n")
cat("Total grid points :", nrow(profile_results), "\n")
cat("Converged         :", sum(profile_results$converged, na.rm = TRUE), "\n")
cat("NAs in nll        :", sum(is.na(profile_results$nll)), "\n")
cat("NLL range         :", range(profile_results$nll, na.rm = TRUE), "\n")
cat("Avg time per job  :", round(mean(profile_results$time_s, na.rm = TRUE), 1), "seconds\n")
cat("MLE NLL           :", mle_nll, "\n")

threshold <- mle_nll + qchisq(0.95, df = 1) / 2
cat("95% threshold     :", threshold, "\n\n")

good <- profile_results %>% filter(converged, !is.na(nll), nll <= threshold)

if (nrow(good) == 0) {
  stop("No profile points below threshold — check worker environment or function guards.")
}

ci_vals <- good %>% summarise(lower = min(f_int), upper = max(f_int))

cat(sprintf("Profile-likelihood 95%% CI for f_int: [%.4f, %.4f]\n",
            ci_vals$lower, ci_vals$upper))

if (ci_vals$lower <= min(f_int_grid) + 0.01)
  warning("Lower CI boundary may be censored — extend grid below ",
          round(min(f_int_grid), 3))
if (ci_vals$upper >= max(f_int_grid) - 0.01)
  warning("Upper CI boundary may be censored — extend grid above ",
          round(max(f_int_grid), 3))

