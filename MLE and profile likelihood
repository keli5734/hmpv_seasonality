prof_plot <- profile_results %>% filter(converged, !is.na(nll)) %>% arrange(f_int)
non_conv  <- profile_results %>% filter(!converged | is.na(nll))

plot(prof_plot$f_int, prof_plot$nll,
     type = "l", lwd = 2,
     xlab = "f_int (viral interference strength)",
     ylab = "-log likelihood",
     main = paste0("Profile Likelihood: f_int  (Region ", region, ")"))

points(mle_f_int, mle_nll, pch = 19, col = "darkgreen", cex = 1.4)
